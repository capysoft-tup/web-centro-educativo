rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Colección users (Perfiles de padres, administradores, etc.)
    match /users/{userId} {
      // Bloquear escrituras directas desde el cliente.
      // Todas las altas y modificaciones deben ocurrir a través de las Cloud Functions.
      allow write: if false;
      
      // Permitir lectura si:
      // 1. El usuario autenticado es dueño de su propio perfil.
      // 2. El usuario autenticado posee el rol 'user_admin' en sus Custom Claims.
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.role == 'user_admin'
      );
    }
    
    // Colección students (Datos y login de alumnos)
    match /students/{studentId} {
      // Bloquear escrituras directas desde el cliente.
      allow write: if false;
      
      // Permitir lectura si:
      // 1. El usuario es el propio alumno (su UID coincide con el ID de documento).
      // 2. El usuario es el padre asociado (su UID coincide con el parentId del alumno).
      // 3. El usuario posee el rol 'user_admin' en sus Custom Claims.
      allow read: if request.auth != null && (
        request.auth.uid == studentId || 
        resource.data.parentId == request.auth.uid || 
        request.auth.token.role == 'user_admin'
      );
    }

    // Colección news (Noticias del portal)
    match /news/{newsId} {
      // Las noticias son públicas para que cualquier visitante del sitio pueda leerlas
      allow read: if true;
      
      // Solo administradores autenticados (con claim de admin o perfil en la bd con rol user_admin) pueden escribir
      allow write: if request.auth != null && (
        request.auth.token.role == 'user_admin' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'user_admin')
      );
    }
  }
}
